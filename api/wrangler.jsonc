{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sde-intern-task-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-22",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "survey",
      "database_id": "54ee4740-2229-439b-bf18-3db5efc6d90a"
    }
  ],

  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "0cd9349dfe8d40198f6254f16763e02c"
    }
  ],

  "vars": {
    "FRONTEND_URL": "https://survey-builder-ekz.pages.dev"
  }

  // Add bindings here as you need them, then run `pnpm cf-typegen` to refresh `Env` types.
  //
  // Examples:
  //
  // "d1_databases": [
  //   { "binding": "DB", "database_name": "survey-builder", "database_id": "<id>" }
  // ],
  //
  // "kv_namespaces": [
  //   { "binding": "SESSIONS", "id": "<id>" }
  // ],
  //
  // "r2_buckets": [
  //   { "binding": "ASSETS", "bucket_name": "survey-builder-assets" }
  // ]
}
